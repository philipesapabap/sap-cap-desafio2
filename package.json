{
  "name": "desafio2",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-ordens": "cds watch --open treinamento.cap.ordens/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-lotes": "cds watch --open treinamento.cap.lotes/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "[development]": {
        "db": "sqlite"
      },
      "auth": {
        "kind": "mocked",
        "users": {
          "100001": {
            "password": "dev",
            "roles": [
              "authenticated-user"
            ]
          },
          "100002": {
            "password": "dev",
            "roles": [
              "authenticated-user"
            ]
          },
          "admin": {
            "password": "admin",
            "roles": [
              "authenticated-user",
              "admin"
            ]
          }
        }
      },
      "[hybrid]": {
        "db": "hana"
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/ordens",
    "app/lotes"
  ]
}
